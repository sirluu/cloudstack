<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="databaseInstanceDaoImpl" class="com.cloud.dbaas.dao.DatabaseInstanceDaoImpl" />
    <bean id="databaseBackupDaoImpl" class="com.cloud.dbaas.dao.DatabaseBackupDaoImpl" />

    <bean id="databaseServiceManagerImpl" class="com.cloud.dbaas.DatabaseServiceManagerImpl">
        <property name="name" value="DatabaseServiceManager" />
    </bean>

</beans>
